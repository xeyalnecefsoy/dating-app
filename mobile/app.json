{
  "expo": {
    "name": "Danyeri",
    "slug": "danyeri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "danyeri",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000108"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "az.danyeri.app"
    },
    "android": {
      "package": "az.danyeri.app",
      "adaptiveIcon": {
        "backgroundColor": "#000108",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7aa1a1fd-e4d4-48f7-93aa-07944402a64e"
      }
    },
    "owner": "xeyalnecefsoy"
  }
}
